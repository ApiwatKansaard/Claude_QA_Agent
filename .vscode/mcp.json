{
	"servers": {
		"figma": {
			"command": "npx",
			"args": ["-y", "figma-developer-mcp", "--figma-api-key=${input:figma_token}", "--stdio"],
			"env": {}
		},
		"atlassian": {
			"command": "/bin/zsh",
			"args": [
				"-c",
				"set -a && source \"${WORKSPACE_FOLDER:-.}/.env\" 2>/dev/null; set +a; exec mcp-atlassian"
			],
			"env": {
				"WORKSPACE_FOLDER": "${workspaceFolder}",
				"ATLASSIAN_BASE_URL": "https://ekoapp.atlassian.net",
				"LOG_LEVEL": "error"
			}
		}
	},
	"inputs": [
		{
			"id": "figma_token",
			"type": "promptString",
			"description": "Figma Personal Access Token (get from figma.com → Settings → Security → Personal access tokens)",
			"password": true
		},
		{
			"id": "atlassian_email",
			"type": "promptString",
			"description": "Atlassian email (e.g. yourname@amitysolutions.com)",
			"password": false
		},
		{
			"id": "atlassian_token",
			"type": "promptString",
			"description": "Atlassian API Token (get from https://id.atlassian.com/manage-profile/security/api-tokens)",
			"password": true
		}
	]
}
