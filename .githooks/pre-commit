#!/usr/bin/env bash
# ============================================================
# Pre-commit Hook — Protect Infrastructure Files
# ============================================================
# Prevents QA team members from accidentally committing changes
# to infrastructure files (skills, prompts, agents, scripts).
#
# Install (one-time, after clone):
#   git config core.hooksPath .githooks
#
# Bypass (team lead only, when intentional):
#   git commit --no-verify
# ============================================================

set -euo pipefail

RED='\033[0;31m'
YELLOW='\033[1;33m'
GREEN='\033[0;32m'
NC='\033[0m'

# Protected path patterns (regex)
PROTECTED_PATHS=(
    "^\.github/skills/"
    "^\.github/agents/"
    "^\.github/prompts/"
    "^\.github/workflows/"
    "^\.vscode/"
    "^scripts/"
    "^README\.md$"
    "^ARCHITECTURE\.md$"
    "^CONTRIBUTING\.md$"
    "^\.github/TEAM-SETUP\.md$"
    "^\.github/CODEOWNERS$"
    "^\.gitignore$"
    "^\.githooks/"
)

# Get list of staged files
STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACMR 2>/dev/null || true)

if [ -z "$STAGED_FILES" ]; then
    exit 0
fi

BLOCKED_FILES=()

for file in $STAGED_FILES; do
    for pattern in "${PROTECTED_PATHS[@]}"; do
        if echo "$file" | grep -qE "$pattern"; then
            BLOCKED_FILES+=("$file")
            break
        fi
    done
done

if [ ${#BLOCKED_FILES[@]} -gt 0 ]; then
    echo ""
    printf "${RED}╔══════════════════════════════════════════════════════╗${NC}\n"
    printf "${RED}║  ⛔  BLOCKED: Infrastructure files are protected    ║${NC}\n"
    printf "${RED}╚══════════════════════════════════════════════════════╝${NC}\n"
    echo ""
    printf "${YELLOW}The following files are managed by the team lead:${NC}\n"
    echo ""
    for f in "${BLOCKED_FILES[@]}"; do
        printf "  ${RED}✗${NC} %s\n" "$f"
    done
    echo ""
    printf "${YELLOW}What to commit instead:${NC}\n"
    printf "  ✅ Sprint artifacts:  agentic-*/, archive/\n"
    printf "  ✅ TestRail cache:    testrail-cache/\n"
    echo ""
    printf "${YELLOW}If you are the team lead making intentional changes:${NC}\n"
    printf "  git commit --no-verify\n"
    echo ""
    exit 1
fi

# ── Sprint artifact validation (non-blocking warnings) ─────

WARNINGS=()

for file in $STAGED_FILES; do
    # Check CSV files have correct column count (15 for TestRail)
    if echo "$file" | grep -qE "testcases\.csv$"; then
        if [ -f "$file" ]; then
            HEADER=$(head -1 "$file" 2>/dev/null || true)
            COL_COUNT=$(echo "$HEADER" | awk -F',' '{print NF}')
            if [ "$COL_COUNT" != "15" ] && [ -n "$COL_COUNT" ]; then
                WARNINGS+=("⚠️  $file has $COL_COUNT columns (expected 15 for TestRail CSV)")
            fi
        fi
    fi

    # Check test plans have required sections
    if echo "$file" | grep -qE "test-plan\.md$"; then
        if [ -f "$file" ]; then
            if ! grep -q "## Scope" "$file" 2>/dev/null; then
                WARNINGS+=("⚠️  $file missing '## Scope' section")
            fi
        fi
    fi
done

if [ ${#WARNINGS[@]} -gt 0 ]; then
    echo ""
    printf "${YELLOW}── Sprint Artifact Warnings ──${NC}\n"
    for w in "${WARNINGS[@]}"; do
        printf "  %s\n" "$w"
    done
    echo ""
    printf "${GREEN}Proceeding with commit (warnings are non-blocking).${NC}\n"
    printf "Run ${YELLOW}/qa:review-before-push${NC} for a full AI review.\n"
    echo ""
fi

exit 0
