# ── QA Agent credentials (DO NOT COMMIT .env) ──────────────────
# Copy this file: cp .env.example .env
# Then fill in YOUR credentials below.

# Jira REST API (for bug reports via Python scripts)
JIRA_EMAIL=yourname@amitysolutions.com
JIRA_TOKEN=your-atlassian-api-token

# Atlassian MCP (for Jira + Confluence via agent)
ATLASSIAN_EMAIL=yourname@amitysolutions.com
ATLASSIAN_API_TOKEN=your-atlassian-api-token
ATLASSIAN_BASE_URL=https://ekoapp.atlassian.net

# TestRail API (for test case management)
TESTRAIL_EMAIL=yourname@amitysolutions.com
TESTRAIL_API_KEY=your-testrail-api-key

# ── How to get credentials ──────────────────────────────────────
# Atlassian: https://id.atlassian.com/manage-profile/security/api-tokens
# TestRail:  https://ekoapp20.testrail.io → Your name → My Settings → API Keys
